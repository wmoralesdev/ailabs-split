// Split — trip cost rooms, members, expenses (integer cents only)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  // Base/settlement currency for the room (e.g. the members' home currency).
  currency    String
  // Allowed currencies for expenses (includes the base currency).
  currencies  String[]     @default([])
  // Exchange rates as units of the currency per 1 base currency, e.g. { "CRC": 505 }.
  fxRates     Json?
  createdAt   DateTime     @default(now())
  members     Member[]
  expenses    Expense[]
  settlements Settlement[]
}

model Member {
  id                         String         @id @default(cuid())
  roomId                     String
  name                       String
  room                       Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  paidExpenses               Expense[]      @relation("ExpensePaidBy")
  shares                     ExpenseShare[]
  settlementPaymentsSent     Settlement[]   @relation("SettlementFrom")
  settlementPaymentsReceived Settlement[]   @relation("SettlementTo")

  @@index([roomId])
}

model Expense {
  id          String         @id @default(cuid())
  roomId      String
  title       String
  amountCents Int
  category    String?
  // Currency this expense was recorded in; null falls back to the room base currency.
  currency    String?
  // How shares were derived: EQUAL | PARTS | AMOUNT.
  splitMode   String         @default("EQUAL")
  // Personal expenses are only visible to the payer and do not affect group settle.
  isPersonal  Boolean        @default(false)
  paidById    String
  createdAt   DateTime       @default(now())
  room        Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  paidBy      Member         @relation("ExpensePaidBy", fields: [paidById], references: [id], onDelete: Restrict)
  shares      ExpenseShare[]

  @@index([roomId])
  @@index([paidById])
}

model ExpenseShare {
  id          String  @id @default(cuid())
  expenseId   String
  memberId    String
  amountCents Int
  // Relative weight when the expense uses PARTS split mode (null otherwise).
  weight      Int?
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member      Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([memberId])
}

model Settlement {
  id           String   @id @default(cuid())
  roomId       String
  fromMemberId String
  toMemberId   String
  amountCents  Int
  currency     String
  createdAt    DateTime @default(now())
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fromMember   Member   @relation("SettlementFrom", fields: [fromMemberId], references: [id], onDelete: Restrict)
  toMember     Member   @relation("SettlementTo", fields: [toMemberId], references: [id], onDelete: Restrict)

  @@index([roomId])
  @@index([fromMemberId])
  @@index([toMemberId])
}
