    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "jsdom": "^28",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^6",
    "vite": "^8",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "esbuild",
      "sharp"
