# Environment variables for Split
# Copy to `.env` for local development.

# Neon Postgres — use the *pooled* connection string (ends with -pooler or
# includes channel_binding / pooler host). Avoid opening many direct connections
# from serverless; this app uses PG_POOL_MAX=1 by default.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Optional: Neon direct (non-pooled) URL for migrations only
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Cap pg Pool size per serverless isolate (default 1)
# PG_POOL_MAX=1

# Mistral OCR — keep unset to disable Scan receipt. Rate-limited server-side.
# Never expose this key to the client.
MISTRAL_API_KEY=""
