# Environment variables for Split
# Copy to `.env` for local development.

# Neon Postgres (pooled URL preferred for serverless)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Optional: Neon direct (non-pooled) URL for migrations
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Mistral OCR (optional until you use Scan receipt)
MISTRAL_API_KEY=""
